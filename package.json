    "lucide-react": "^0.546.0",
    "motion": "^12.38.0",
    "next": "16.2.6",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "server-only": "^0.0.1",
    "supabase": "^2.98.2",
    "zod": "^4.4.1"
  },
  "devDependencies": {
