    "verify:release": "npm run lint && npm run typecheck && npm run format:check && npm run build && npm run check:build-budget",
    "smoke:routes": "node scripts/smoke-routes.mjs",
    "format": "prettier --write \"**/*.{js,mjs,cjs,jsx,ts,tsx,css,json}\"",
    "format:check": "prettier --check \"**/*.{js,mjs,cjs,jsx,ts,tsx,css,json}\""
